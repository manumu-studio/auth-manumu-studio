{
  "name": "auth-manumu-studio",
  "version": "1.8.5",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "pnpm prisma:generate && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "exec vitest run",
    "test:watch": "vitest --watch",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "smoke": "tsx -e \"fetch('http://localhost:3000/api/healthz').then(r=>r.text()).then(console.log)\"",
    "scaffold:verify": "APPLY=1 ./verify-email-scaffold.sh",
    "prepare": "husky install"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@prisma/client": "^6.16.3",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.34.9",
    "bcryptjs": "^3.0.2",
    "framer-motion": "^12.23.22",
    "next": "^15.5.19",
    "next-auth": "^4.24.12",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resend": "^6.1.2",
    "sass": "^1.93.0",
    "zod": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "defu": ">=6.1.7",
      "effect": ">=3.21.4",
      "preact": ">=10.29.2",
      "immutable": ">=5.1.6",
      "minimatch@<3.1.5": "3.1.5",
      "minimatch@>=9.0.0 <9.0.9": "9.0.9",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "flatted": ">=3.4.2",
      "rollup@<4.59.0": "4.62.2"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.36.0",
    "@next/eslint-plugin-next": "^15.5.7",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.19.19",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.2.3",
    "eslint": "^9.36.0",
    "eslint-config-next": "^15.5.19",
    "globals": "^16.4.0",
    "husky": "^8.0.0",
    "postcss": "^8.5.6",
    "prisma": "^6.16.3",
    "sharp": "^0.34.5",
    "tailwindcss": "3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
