# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# NextAuth / application URLs
NEXTAUTH_SECRET=replace_with_at_least_32_random_characters
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# RS256 OAuth/OIDC signing keys
# Preserve line breaks as \n when storing PEM values in hosted environments.
OAUTH_JWT_PRIVATE_KEY=
OAUTH_JWT_PUBLIC_KEY=
OAUTH_JWT_KID=

# Optional social providers; each provider requires both values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend email delivery
RESEND_API_KEY=
RESEND_FROM="ManuMu Authentication <auth@example.com>"

# Email verification
VERIFY_TOKEN_TTL_MINUTES=10
VERIFY_RESEND_COOLDOWN_MINUTES=2

# Password reset
RESET_TOKEN_TTL_MINUTES=30
RESET_RESEND_COOLDOWN_MINUTES=2

# Rate limiting
# These become mandatory in production in PACKET-security-hardening-now.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_MAX=3
RATE_LIMIT_WINDOW_MINUTES=60

# Declared security configuration.
# These values are not fully enforced yet; see Incident P001.
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_MINUTES=30
SESSION_IDLE_TIMEOUT_MINUTES=30
MFA_ISSUER="ManuMu Studio"
HIBP_ENABLED=false

# OTP HMAC — protects stored OTP hashes against DB-leak rainbow-table attacks.
# Generate: openssl rand -hex 32
OTP_HMAC_SECRET=

# Self-service registration kill switch.
# Set to "false" in production until invite/allowlist gating ships (PACKET-02).
# Allowed values: "true" | "false"
SELF_SERVICE_REGISTRATION_ENABLED=false

# Seed script — development only, never set these in production.
# Generate passwords: openssl rand -base64 16
# Generate OAuth secret: openssl rand -hex 32
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD=
SEED_OAUTH_CLIENT_SECRET=
SEED_CONFIRMATION=DEVELOPMENT_ONLY
